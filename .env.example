# ── Splunk MCP Server ─────────────────────────────────────────────────────────
# Encrypted token generated inside the Splunk MCP Server app (one-time display)
SPLUNK_MCP_ENCRYPTED_TOKEN=your_encrypted_token_here

# Full URL of your Splunk MCP Server endpoint (no trailing slash)
# On-prem example:  https://splunk.yourcompany.com:8000/services/mcp/v1
# Cloud example:    https://<stack>.splunkcloud.com/services/mcp/v1
SPLUNK_MCP_ENDPOINT=https://your-splunk-host:8000/services/mcp/v1

# Used by Layer 5 telemetry — same host, REST API port
SPLUNK_HOST=your-splunk-host
SPLUNK_PORT=8089
SPLUNK_REST_TOKEN=your_splunk_rest_token_here

# ── Proxy settings ─────────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# ── Gemini (supervisor LLM) ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── LangSmith (optional tracing) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=aicb-splunk

# ── Query memory ──────────────────────────────────────────────────────────────
MEMORY_DB_PATH=./memory/query_cache.db
